# Server
SERVER_PORT=8080
SERVER_HOST=0.0.0.0
SERVER_ENV=development

# Database
DATABASE_URL=postgres://webhostmanager:secret@localhost:5432/webhostmanager?sslmode=disable
MIGRATIONS_PATH=file://migrations

# Auth — CHANGE THESE IN PRODUCTION
JWT_SECRET=your-super-secret-jwt-key-min-32-chars
JWT_EXPIRY_HRS=24
ENCRYPTION_KEY=your-32-char-aes-encryption-key!

# CORS
ALLOWED_ORIGINS=http://localhost:3000
